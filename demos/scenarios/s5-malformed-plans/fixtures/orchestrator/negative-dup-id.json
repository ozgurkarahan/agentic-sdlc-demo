{
  "agent": "orchestrator",
  "case": "negative-duplicate-unit-id",
  "polarity": "negative",
  "enforcement": "local-assertion",
  "driver": "plan-lint",
  "title": "A plan with two units sharing the same id (U1 twice) must be caught — duplicate ids make the DAG ambiguous and break dependency resolution",
  "input": {
    "plan": {
      "intent": "Add a slug-collision guard (with a duplicate id).",
      "planApproved": false,
      "units": [
        { "id": "U1", "title": "helper", "paths": ["demos/sample-app/src/lib/slug.ts"], "parallelSafe": false, "dependsOn": [] },
        { "id": "U1", "title": "config (accidentally reused id U1)", "paths": ["demos/sample-app/src/config.ts"], "parallelSafe": false, "dependsOn": [] }
      ]
    }
  },
  "expect": {
    "outcome": "blocked",
    "signals": ["malformed-plan"]
  }
}
