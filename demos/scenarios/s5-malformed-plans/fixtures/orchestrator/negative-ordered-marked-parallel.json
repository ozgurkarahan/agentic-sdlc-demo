{
  "agent": "orchestrator",
  "case": "negative-ordered-unit-marked-parallel",
  "polarity": "negative",
  "enforcement": "local-assertion",
  "driver": "plan-lint",
  "title": "A unit that dependsOn a predecessor but is marked parallelSafe:true is a contradiction — a dependent unit cannot run in the parallel wave. plan-lint rule A must catch it",
  "input": {
    "plan": {
      "intent": "Add a slug-collision guard (with a mislabeled dependent unit).",
      "planApproved": false,
      "units": [
        { "id": "U1", "title": "collision-guard helper", "paths": ["demos/sample-app/src/lib/slug.ts"], "parallelSafe": true, "dependsOn": [] },
        { "id": "U2", "title": "wiring that consumes the helper", "paths": ["demos/sample-app/src/app.ts"], "parallelSafe": true, "dependsOn": ["U1"] }
      ]
    }
  },
  "expect": {
    "outcome": "blocked",
    "signals": ["ordered-unit-marked-parallel"]
  }
}
