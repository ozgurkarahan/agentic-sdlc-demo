{
  "agent": "orchestrator",
  "case": "negative-dependency-cycle",
  "polarity": "negative",
  "enforcement": "local-assertion",
  "driver": "plan-lint",
  "title": "A plan whose units form a dependency cycle (U1→U3→U2→U1) must be caught by the dispatcher's DAG validation — a cycle can never be scheduled",
  "input": {
    "plan": {
      "intent": "Add a slug-collision guard (with a circular plan).",
      "planApproved": false,
      "units": [
        { "id": "U1", "title": "helper", "paths": ["demos/sample-app/src/lib/slug.ts"], "parallelSafe": false, "dependsOn": ["U3"] },
        { "id": "U2", "title": "wiring", "paths": ["demos/sample-app/src/app.ts"], "parallelSafe": false, "dependsOn": ["U1"] },
        { "id": "U3", "title": "config", "paths": ["demos/sample-app/src/config.ts"], "parallelSafe": false, "dependsOn": ["U2"] }
      ]
    }
  },
  "expect": {
    "outcome": "blocked",
    "signals": ["malformed-plan"]
  }
}
